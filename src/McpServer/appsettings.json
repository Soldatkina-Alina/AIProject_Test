{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "FormatterName": "simple"
    },
    "File": {
      "Path": "logs/mcp-server-.log",
      "RollingInterval": "Day",
      "FileSizeLimitBytes": 10485760,
      "RetainedFileCountLimit": 30
    }
  },
  "PromoCodeFactoryApi": {
    "BaseUrl": "http://localhost:5001",
    "Timeout": 30
  },
  "AllowedHosts": "*"
}